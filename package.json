{
  "name": "cyber-wiki-front",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": ">=25.1.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "eslint-plugin-local"
  ],
  "scripts": {
    "generate:mfe-manifests": "tsx scripts/generate-mfe-manifests.ts",
    "dev": "tsx scripts/generate-mfe-manifests.ts && vite",
    "dev:all": "tsx scripts/generate-mfe-manifests.ts && tsx scripts/dev-all.ts",
    "check:mcp": "tsx scripts/check-mcp.ts",
    "build": "tsx scripts/generate-mfe-manifests.ts && vite build",
    "preview": "vite preview",
    "lint": "npm run build --workspace=eslint-plugin-local && eslint . --max-warnings 0",
    "lint:check-disables": "bash scripts/check-eslint-disables.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "arch:check": "tsx scripts/test-architecture.ts",
    "knip": "knip",
    "arch:deps": "dependency-cruiser src/ --config .dependency-cruiser.cjs --output-type err-long",
    "ai:sync": "frontx ai sync",
    "prek:install": "prek install",
    "prek:run": "prek run --all-files",
    "postinstall": "prek install"
  },
  "dependencies": {
    "@cyberfabric/api": "alpha",
    "@cyberfabric/framework": "alpha",
    "@cyberfabric/i18n": "alpha",
    "@cyberfabric/react": "alpha",
    "@cyberfabric/screensets": "alpha",
    "@cyberfabric/state": "alpha",
    "@hookform/resolvers": "5.2.2",
    "@iconify/react": "5.0.2",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@radix-ui/react-avatar": "1.1.10",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "1.2.3",
    "@reduxjs/toolkit": "2.11.2",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/query-core": "5.90.20",
    "@tanstack/react-query": "5.90.21",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "input-otp": "1.4.2",
    "lodash": "4.18.1",
    "lucide-react": "0.563.0",
    "react": "19.2.4",
    "react-day-picker": "9.12.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.68.0",
    "react-markdown": "10.1.0",
    "react-redux": "9.2.0",
    "react-syntax-highlighter": "16.1.1",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.3.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.0.0"
  },
  "devDependencies": {
    "@cyberfabric/cli": "alpha",
    "@eslint/js": "9.27.0",
    "@j178/prek": "0.3.11",
    "@module-federation/vite": "^1.14.2",
    "@types/lodash": "4.17.20",
    "@types/node": "^25.6.0",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.18",
    "dependency-cruiser": "17.3.2",
    "eslint": "9.27.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "15.12.0",
    "knip": "^5.62.0",
    "postcss": "8.4.35",
    "postcss-load-config": "6.0.1",
    "tailwindcss": "3.4.1",
    "tsx": "4.20.6",
    "typescript": "5.4.2",
    "typescript-eslint": "8.32.1",
    "vite": "6.4.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@isaacs/brace-expansion": "5.0.1",
    "axios": "1.15.2",
    "lodash": "$lodash",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4"
  }
}
